[run]
source = .
omit = tests/*,*/migrations/*,*/__pycache__/*,*/venv/*,*/site-packages/*,deploy.sh,uninstall.sh,*.sh

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    logger\.
    logging\.
fail_under = 25
show_missing = True
skip_covered = False

[html]
directory = htmlcov
