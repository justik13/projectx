# ==================== Telegram Bot ====================
# Токен бота от @BotFather
BOT_TOKEN=

# Telegram ID администратора (получить через @userinfobot)
ADMIN_IDS=[1234567890,1234567890]

# Режим работы: all = для всех, admin = только для администратора
BOT_MODE=all

VPN_HOST=domain.wtf

# ==================== Amnezia API ====================
# Адрес API (http://IP:PORT)
AMNEZIA_API_URL=http://localhost:4001

# Ключ API из .env amnezia-api (FASTIFY_API_KEY)
AMNEZIA_API_KEY=

# Протокол для создания пользователей: amneziawg2 или xray
AMNEZIA_PROTOCOL=amneziawg2

# ==================== База данных ====================
# Путь к SQLite базе данных
DB_PATH=./bot_data.db

DB_ENCRYPTION_KEY=
# 44 символа 
# Строчные буквы латиницы: a–z
# Заглавные буквы латиницы: A–Z
# Цифры: 0–9
# Специальные символы: -, _, =
# ==================== Mini App (Flask-сервер) ====================

# Хост и порт Flask-сервера Mini App
# По умолчанию слушает на всех интерфейсах, порт 5000
MINIAPP_HOST=0.0.0.0
MINIAPP_PORT=4999

# Режим разработки
WEB_HOST=0.0.0.0
WEB_PORT=5000
MINIAPP_DEV_MODE=False

# ════════════════════════════════════════════
# Короткие ссылки
# ════════════════════════════════════════════
SHORT_LINK_DOMAIN=domain.wtf
