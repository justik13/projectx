# ============================================================
# ProjectX Bot — .env.example
# ============================================================
# Скопируйте этот файл в .env и заполните реальные значения.
#
#   cp .env.example .env
#   chmod 600 .env
#
# Никогда не коммитьте .env в git.
# ============================================================


# ------------------------------------------------------------
# Telegram Bot
# ------------------------------------------------------------

# Токен бота от @BotFather
BOT_TOKEN='1234567890:CHANGE_ME_TELEGRAM_BOT_TOKEN'

# Telegram ID администраторов через запятую.
# Пример: 111111111,222222222
ADMIN_IDS='111111111'

# Username поддержки.
# Можно с @ или без.
SUPPORT_USERNAME='support'


# ------------------------------------------------------------
# База данных PostgreSQL
# ------------------------------------------------------------

# Пример для локального PostgreSQL:
DATABASE_URL='postgresql+asyncpg://projectx:CHANGE_ME_DB_PASSWORD@localhost:5432/projectx_bot'

# Если в пароле БД есть спецсимволы, их нужно URL-encode.
# Например:
#   пароль: p@ss:word/123
#   encoded: p%40ss%3Aword%2F123
#
# Итог:
# DATABASE_URL='postgresql+asyncpg://projectx:p%40ss%3Aword%2F123@localhost:5432/projectx_bot'


# ------------------------------------------------------------
# Шифрование чувствительных данных в БД
# ------------------------------------------------------------

# Обязательный ключ шифрования.
# Используется для хранения API-ключей серверов Amnezia.
#
# Сгенерировать:
#
#   python3 -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#
# ВАЖНО:
# - не теряйте этот ключ;
# - не меняйте его после создания серверов, иначе старые API-ключи не расшифруются;
# - храните в бэкапах вместе с БД.
DB_ENCRYPTION_KEY='CHANGE_ME_BASE64_32_BYTES_FERNET_KEY'


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

# Redis используется для FSM, lock'ов и временных данных.
# Для production обязательно используйте пароль.

# Пример без пароля, только для локальной разработки:
# REDIS_URL='redis://localhost:6379/0'

# Пример с паролем:
REDIS_URL='redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0'

# Опционально: пароль Redis как отдельная переменная.
# Используется deploy.sh, но не обязателен для самого бота,
# если REDIS_URL уже содержит пароль.
REDIS_PASSWORD='CHANGE_ME_REDIS_PASSWORD'

# Префикс ключей Redis.
REDIS_KEY_PREFIX='projectx_bot:'


# ------------------------------------------------------------
# Настройки доступа к локальным сетям / SSRF protection
# ------------------------------------------------------------

# По умолчанию бот запрещает подключение к локальным адресам.
# Это защита от SSRF.

# Разрешать ли локальный HTTP.
# Ставьте true ТОЛЬКО если Amnezia API находится локально, например:
#   http://127.0.0.1:4001
#
# Для production с внешним HTTPS API оставляйте false.
ALLOW_LOCAL_HTTP=false

# Разрешать ли локальный HTTPS.
# Обычно не нужно.
ALLOW_LOCAL_HTTPS=false


# ------------------------------------------------------------
# Платёжная система Platega / SBP
# ------------------------------------------------------------

# Если PLATEGA_MERCHANT_ID и PLATEGA_SECRET пустые:
# - SBP-кнопка не показывается;
# - webhook-сервер Platega не запускается;
# - остаются только Telegram Stars.
#
# Если оба значения заполнены:
# - включается SBP;
# - запускается локальный webhook-сервер на 127.0.0.1:PLATEGA_WEBHOOK_PORT;
# - Nginx должен проксировать HTTPS на этот порт.

PLATEGA_MERCHANT_ID=''
PLATEGA_SECRET=''

# Базовый URL Platega API.
PLATEGA_BASE_URL='https://app.platega.io'

# Публичный callback URL для Platega.
# Должен быть доступен по HTTPS.
# Пример:
#   https://pay.example.com/webhook/platega
PLATEGA_CALLBACK_URL=''

# Локальный порт webhook-сервера внутри сервера.
# Nginx проксирует HTTPS на 127.0.0.1:8080.
PLATEGA_WEBHOOK_PORT=8080

# Метод оплаты Platega.
# 2 — SBP / платёжная страница.
PLATEGA_PAYMENT_METHOD=2

# URL возврата после оплаты.
# {bot_username} будет заменён на username бота.
PLATEGA_RETURN_URL='https://t.me/{bot_username}'

# URL при ошибке оплаты.
PLATEGA_FAILED_URL='https://t.me/{bot_username}'
