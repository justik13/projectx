# ============================================================
# 📋 ProjectX Bot — Конфигурация окружения
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# 🔐 ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ
# ----------------------------------------------------------

# Telegram Bot Token (получить у @BotFather через /newbot)
# Формат: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=

# Telegram ID администраторов (через запятую, БЕЗ пробелов)
# Узнать свой ID: написать @userinfobot
# Пример: 123456789,987654321
ADMIN_IDS=

# ----------------------------------------------------------
# ⚙️ НАСТРОЙКИ СЕРВИСА
# ----------------------------------------------------------

# Username поддержки (БЕЗ знака @, будет использован в ссылках t.me/username)
# Пользователи будут видеть: "Написать @support_username"
SUPPORT_USERNAME=support_username

# Бонус рефереру за ПЕРВУЮ оплату приглашённого друга (в днях)
# При оплате другом, реферер получает +N дней к подписке
REFERRAL_BONUS_DAYS=3

# ----------------------------------------------------------
# 🗄 БАЗА ДАННЫХ
# ----------------------------------------------------------

# Путь к файлу базы данных SQLite (относительно WorkingDirectory)
DB_PATH=./bot_data.db

# ----------------------------------------------------------
# 🔒 ШИФРОВАНИЕ (АВТОГЕНЕРАЦИЯ)
# ----------------------------------------------------------

# Ключ шифрования Fernet для защиты чувствительных данных в БД:
# - peer_id (идентификаторы клиентов на Amnezia-серверах)
# - raw_config (конфиги подключений vpn://...)
# - api_key (ключи доступа к Amnezia API)
#
# ⚠️ НЕ МЕНЯЙТЕ вручную на работающей БД — все зашифрованные данные
#    станут недоступны (потребуется полный сброс БД).
#
# Генерируется автоматически при первом запуске deploy.sh.
# Можно сгенерировать вручную:
# python3 -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
DB_ENCRYPTION_KEY=