# ═══════════════════════════════════════════════════════════════
# ProjectX Bot Configuration
# ═══════════════════════════════════════════════════════════════

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=

# Telegram ID администраторов (через запятую, без пробелов)
# Узнать свой ID: написать @userinfobot
ADMIN_IDS=

# Username поддержки (без @)
SUPPORT_USERNAME=

# Бонус рефереру за первую оплату друга (в днях)
REFERRAL_BONUS_DAYS=3

# Лимит устройств по умолчанию для новых пользователей
DEFAULT_DEVICE_LIMIT=3

# Путь к базе данных SQLite
DATABASE_URL=sqlite+aiosqlite:///./bot_data.db